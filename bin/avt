#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT_DIR="$ROOT_DIR/skills/audio-video-transcriber/scripts"

show_help() {
  cat <<'EOF'
Audio Video Transcriber Toolkit

Usage:
  ./bin/avt doctor
  ./bin/avt install
  ./bin/avt bootstrap
  ./bin/avt transcribe "/path/to/file.mp4" [transcribe options]
  ./bin/avt watch
  ./bin/avt stop
  ./bin/avt status
  ./bin/avt help

Examples:
  ./bin/avt doctor
  ./bin/avt bootstrap
  ./bin/avt transcribe ~/Desktop/test.mp4
  ./bin/avt transcribe ~/Desktop/test.mp4 --model medium --language auto
  ./bin/avt watch
  ./bin/avt stop
  ./bin/avt status
EOF
}

if [ "$#" -eq 0 ]; then
  show_help
  exit 1
fi

COMMAND="$1"
shift || true

case "$COMMAND" in
  --help|-h|help)
    show_help
    ;;
  doctor)
    "$SCRIPT_DIR/doctor.sh" "$@"
    ;;
  install)
    "$SCRIPT_DIR/install_whisper.sh" "$@"
    ;;
  bootstrap)
    "$SCRIPT_DIR/bootstrap.sh" --yes "$@"
    ;;
  transcribe)
    if [ "$#" -lt 1 ]; then
      echo "Missing input file."
      echo
      echo "Example:"
      echo "  ./bin/avt transcribe \"/path/to/file.mp4\""
      exit 1
    fi
    python3 "$SCRIPT_DIR/transcribe.py" "$@"
    ;;
  watch)
    "$SCRIPT_DIR/start_watcher.sh" "$@"
    ;;
  stop)
    "$SCRIPT_DIR/stop_watcher.sh" "$@"
    ;;
  status)
    "$SCRIPT_DIR/status.sh" "$@"
    ;;
  *)
    echo "Unknown command: $COMMAND"
    echo
    show_help
    exit 1
    ;;
esac
